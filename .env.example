# Microsoft Entra ID (Azure AD)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Development auth bypass (set to true for local dev without Entra ID)
DEV_AUTH=true

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# App
SECRET_KEY=change-me-to-a-random-secret-string
DATABASE_URL=sqlite:///./app.db
PDF_STORAGE_PATH=./static/pdfs

# Comma-separated list of emails granted admin role on first login
ADMIN_EMAILS=admin@example.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
